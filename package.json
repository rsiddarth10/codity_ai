{
  "name": "codity",
  "version": "0.1.0",
  "private": true,
  "description": "Distributed job scheduling platform (Postgres-backed).",
  "type": "module",
  "workspaces": [
    "packages/*",
    "frontend"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "migrate": "node packages/db/scripts/migrate.mjs",
    "migrate:up": "node packages/db/scripts/migrate.mjs up",
    "migrate:down": "node packages/db/scripts/migrate.mjs down",
    "migrate:create": "node packages/db/scripts/migrate.mjs create",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "puppeteer-core": "^23.11.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1"
  }
}
