# ---- Database ----
# Host connection string (used by migrations, tests, and services running on the host).
DATABASE_URL=postgres://codity:codity@localhost:5432/codity

# Postgres container bootstrap (docker-compose)
POSTGRES_USER=codity
POSTGRES_PASSWORD=codity
POSTGRES_DB=codity
POSTGRES_PORT=5432

# ---- Auth ----
# Use long random values in any real deployment.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900          # seconds (15m)
JWT_REFRESH_TTL=1209600     # seconds (14d)
BCRYPT_ROUNDS=10

# ---- API ----
API_PORT=4000
LOG_LEVEL=info
NODE_ENV=development

# ---- Worker ----
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
WORKER_POLL_JITTER_MS=250
WORKER_HEARTBEAT_INTERVAL_MS=5000
# A claimed job's lock is valid for this long; heartbeats extend it. Reaper requeues past this.
JOB_LOCK_DURATION_MS=30000
WORKER_SHUTDOWN_TIMEOUT_MS=25000

# ---- Scheduler / Reaper ----
SCHEDULER_POLL_INTERVAL_MS=1000
REAPER_POLL_INTERVAL_MS=5000
# A worker is considered dead if it has not heartbeat within this window.
WORKER_DEAD_AFTER_MS=30000
